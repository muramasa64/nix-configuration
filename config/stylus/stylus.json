    "sourceCode": "/* ==UserStyle==\n@name           app.slack.com\n@namespace      github.com/openstyles/stylus\n@version        1.0.0\n@description    A new userstyle\n@author         Me\n==/UserStyle== */\n\n@-moz-document url-prefix(\"https://app.slack.com/client\") {\n    /* ここにコードを挿入... */\n    [lang=ja-JP] * {\n        font-family: \"UDEV Gothic 35JPDOC\" !important;\n        overflow-wrap: anywhere; /* 収まらない場合に折り返す */\n        word-break: normal; /* 単語の分割はデフォルトに依存 */\n        line-break: strict; /* 禁則処理を厳格に適用 */\n        text-autospace: normal; /* 和文中の英数字に余白 */\n    }\n    .c-text_input {\n        font-family: \"UDEV Gothic 35JPDOC\" !important;\n    }\n    .p-tab_rail__shortcut_hint {\n        display: none;\n    }\n}",
    "usercssData": {
      "name": "app.slack.com",
      "namespace": "github.com/openstyles/stylus",
      "version": "1.0.0",
      "description": "A new userstyle",
      "author": "Me"
    },
